{
  "name": "okit-cli",
  "version": "2.1.5",
  "description": "OKIT - Agent infrastructure toolkit for managing dev tools, auth, and upgrades",
  "main": "dist/main.js",
  "bin": {
    "okit": "dist/main.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-web && npm run copy-tools",
    "copy-web": "rm -rf dist/web && mkdir -p dist/web && cp -r src/web/public dist/web/ && cp src/web/server.js dist/web/ && cp -r src/web/api dist/web/",
    "copy-tools": "mkdir -p dist/config/tools && cp src/config/tools/*.yaml dist/config/tools/",
    "dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "pkg": "pkg . --out-path=bin"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.map",
    "dist/**/*.html",
    "dist/**/*.css",
    "dist/**/*.yaml",
    "!dist/release",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "agent",
    "devtools",
    "installer",
    "infrastructure"
  ],
  "author": "dolphin-molt",
  "repository": {
    "type": "git",
    "url": "https://github.com/dolphin-molt/okit.git"
  },
  "license": "MIT",
  "dependencies": {
    "@types/express": "^5.0.6",
    "commander": "^11.0.0",
    "execa": "^5.1.1",
    "express": "^5.2.1",
    "fs-extra": "^11.1.1",
    "js-yaml": "^4.1.1",
    "kleur": "^4.1.5",
    "ora": "^5.4.1",
    "prompts": "^2.4.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.5.0",
    "@types/prompts": "^2.4.4",
    "@types/ws": "^8.18.1",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node18-macos-arm64",
      "node18-macos-x64"
    ],
    "outputPath": "bin"
  }
}
